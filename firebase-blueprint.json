{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "A message submitted via the Contact Us form.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "User's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email"
        },
        "subject": {
          "type": "string",
          "description": "Subject or topic of the message"
        },
        "message": {
          "type": "string",
          "description": "The message itself"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the message was submitted"
        }
      },
      "required": ["fullName", "email", "subject", "message", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile data stored upon first login.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "providerId": { "type": "string" },
        "hasAcceptedLegal": { "type": "integer", "description": "1 if legal terms accepted, 0 otherwise" },
        "legalAcceptedAt": { "type": "timestamp", "description": "When the legal terms were accepted" },
        "lastLogin": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" },
        "createdAt": { "type": "timestamp" },
        "metadata": {
          "type": "object",
          "properties": {
            "device": { "type": "string" },
            "os": { "type": "string" },
            "browser": { "type": "string" },
            "ip": { "type": "string" },
            "location": { "type": "string" }
          }
        }
      },
      "required": ["userId", "lastLogin"]
    },
    "UserMoon": {
      "title": "User Katina Moon Balance",
      "description": "Stores current balance of Katina Moons for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "integer" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "balance", "updatedAt"]
    },
    "MoonTransaction": {
      "title": "Katina Moon Transaction",
      "description": "Logs when a user spends or receives Katina Moons.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "integer" },
        "type": { "type": "string", "enum": ["spend", "buy", "bonus"] },
        "description": { "type": "string" },
        "pdfDownloaded": { "type": "integer", "description": "1 if PDF was downloaded, 0 otherwise" },
        "userName": { "type": "string" },
        "userDob": { "type": "string" },
        "userBirthplace": { "type": "string" },
        "userRelationship": { "type": "string" },
        "userLanguage": { "type": "string", "description": "The language selected by the user" },
        "selectedCards": { "type": "array", "items": { "type": "string" } },
        "cardIds": { "type": "array", "items": { "type": "string" } },
        "readingText": { "type": "string", "description": "The generated reading text" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "amount", "type", "createdAt"]
    },
    "UserEvent": {
      "title": "User Event",
      "description": "Logs in-app usage and performance events.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "eventType": { "type": "string" },
        "eventData": { "type": "object" },
        "performance": { "type": "object" },
        "timestamp": { "type": "timestamp" }
      },
      "required": ["userId", "eventType", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Stores user profile information"
    },
    "/user_events/{eventId}": {
      "schema": { "$ref": "UserEvent" },
      "description": "Logs user-specific events and performance"
    },
    "/user_moons/{userId}": {
      "schema": { "$ref": "UserMoon" },
      "description": "Stores user moon balance"
    },
    "/moon_transactions/{transactionId}": {
      "schema": { "$ref": "MoonTransaction" },
      "description": "Logs moon transactions"
    },
    "/messages_en/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores contact us messages from users in English"
    },
    "/messages_tr/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores contact us messages from users in Turkish"
    },
    "/messages_es/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores contact us messages from users in Spanish"
    },
    "/messages_fr/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores contact us messages from users in French"
    },
    "/messages_zh/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores contact us messages from users in Chinese"
    },
    "/messages_ko/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores contact us messages from users in Korean"
    }
  }
}
