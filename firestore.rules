rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['fullName', 'email', 'subject', 'message', 'createdAt']) && 
             data.keys().size() == 5 &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.subject is string && data.subject.size() <= 150 &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.userId == request.auth.uid &&
             data.keys().hasAll(['userId', 'lastLogin']) &&
             (!('hasAcceptedLegal' in data) || (data.hasAcceptedLegal is int && data.hasAcceptedLegal in [0, 1])) &&
             (!('legalAcceptedAt' in data) || data.legalAcceptedAt is timestamp) &&
             (!('metadata' in data) || data.metadata is map);
    }

    function isValidUserMoon(data) {
      return data.userId == request.auth.uid &&
             data.balance is int;
    }

    function isValidMoonTransaction(data) {
      return data.userId == request.auth.uid &&
             data.amount is int &&
             data.type in ['spend', 'buy', 'bonus'] &&
             data.description is string &&
             data.pdfDownloaded is int &&
             data.pdfDownloaded in [0, 1] &&
             (!('userName' in data) || (data.userName is string && data.userName.size() < 500)) &&
             (!('userDob' in data) || (data.userDob is string && data.userDob.size() < 100)) &&
             (!('userBirthplace' in data) || (data.userBirthplace is string && data.userBirthplace.size() < 200)) &&
             (!('userRelationship' in data) || (data.userRelationship is string && data.userRelationship.size() < 100)) &&
             (!('userLanguage' in data) || (data.userLanguage is string && data.userLanguage.size() < 10)) &&
             (!('selectedCards' in data) || (data.selectedCards is list && data.selectedCards.size() <= 10)) &&
             (!('cardIds' in data) || (data.cardIds is list && data.cardIds.size() <= 10)) &&
             (!('readingText' in data) || (data.readingText is string && data.readingText.size() < 10000));
    }

    function isValidUserEvent(data) {
      return data.userId == request.auth.uid &&
             data.eventType is string &&
             data.timestamp == request.time;
    }

    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && isValidUser(request.resource.data);
    }

    match /user_moons/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && isValidUserMoon(request.resource.data);
    }

    match /moon_transactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && isValidMoonTransaction(request.resource.data);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && isValidMoonTransaction(request.resource.data);
    }

    match /user_events/{eventId} {
      allow create: if request.auth != null && isValidUserEvent(request.resource.data);
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /messages_en/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_tr/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_es/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_fr/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_zh/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_ko/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
  }
}
