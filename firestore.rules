rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isEmployee() {
      return request.auth != null && 
             ('role' in request.auth.token) &&
             (request.auth.token.role == 'employee' || request.auth.token.role == 'admin');
    }

    function isAdmin() {
      return request.auth != null && 
             ('role' in request.auth.token) &&
             request.auth.token.role == 'admin';
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['fullName', 'email', 'subject', 'message', 'createdAt']) && 
             data.keys().size() == 5 &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.subject is string && data.subject.size() <= 150 &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.userId == request.auth.uid &&
             data.keys().hasAll(['userId', 'lastLogin']) &&
             (!('password' in data) || (data.password is string && data.password.size() <= 256)) &&
             (!('hasAcceptedLegal' in data) || (data.hasAcceptedLegal is int && data.hasAcceptedLegal in [0, 1])) &&
             (!('legalAcceptedAt' in data) || data.legalAcceptedAt is timestamp) &&
             (!('consentsAcceptedAt' in data) || data.consentsAcceptedAt is timestamp) &&
             (!('metadata' in data) || data.metadata is map) &&
             (!('providerId' in data) || (data.providerId == null || data.providerId is string)) &&
             (!('emailVerified' in data) || data.emailVerified is bool) &&
             (!('isAnonymous' in data) || data.isAnonymous is bool) &&
             (!('profile' in data) || (data.profile == null || data.profile is map)) &&
             (!('termsAccepted' in data) || data.termsAccepted is bool) &&
             (!('termsAcceptedAt' in data) || data.termsAcceptedAt is timestamp) &&
             (!('termsVersion' in data) || (data.termsVersion is string && data.termsVersion.size() <= 50)) &&
             (!('timezone' in data) || (data.timezone is string && data.timezone.size() <= 100)) &&
             (!('deviceInfo' in data) || (data.deviceInfo is string && data.deviceInfo.size() <= 256)) &&
             (!('appVersion' in data) || (data.appVersion is string && data.appVersion.size() <= 50)) &&
             (!('lifetimeValue' in data) || (data.lifetimeValue is number || data.lifetimeValue is float || data.lifetimeValue is int));
    }

    function isValidUserMoon(data) {
      return data.userId == request.auth.uid &&
             data.balance is int &&
             (!('dailyFreeBalance' in data) || data.dailyFreeBalance is int) &&
             (!('purchasedBalance' in data) || data.purchasedBalance is int) &&
             (!('lastDailyClaimedAt' in data) || data.lastDailyClaimedAt == null || data.lastDailyClaimedAt is timestamp);
    }

    function isValidMoonTransaction(data, transactionId) {
      return (data.userId == request.auth.uid || isEmployee()) &&
             data.amount is int &&
             data.type in ['spend', 'buy', 'bonus', 'refund'] &&
             data.description is string &&
             data.pdfDownloaded is int &&
             data.pdfDownloaded in [0, 1] &&
             (!('transactionId' in data) || data.transactionId == transactionId) &&
             (!('performedBy' in data) || data.performedBy is string) &&
             (!('targetUser' in data) || data.targetUser is string) &&
             (!('status' in data) || data.status in ['pending', 'success', 'failed', 'cached']) &&
             (!('userName' in data) || (data.userName is string && data.userName.size() < 500)) &&
             (!('userDob' in data) || (data.userDob is string && data.userDob.size() < 100)) &&
             (!('userBirthplace' in data) || (data.userBirthplace is string && data.userBirthplace.size() < 200)) &&
             (!('userRelationship' in data) || (data.userRelationship is string && data.userRelationship.size() < 100)) &&
             (!('userLanguage' in data) || (data.userLanguage is string && data.userLanguage.size() < 10)) &&
             (!('selectedCards' in data) || (data.selectedCards is list && data.selectedCards.size() <= 10)) &&
             (!('isFavorite' in data) || data.isFavorite is bool) &&
             (!('customTitle' in data) || (data.customTitle is string && data.customTitle.size() <= 200)) &&
             (!('reflectionNotes' in data) || (data.reflectionNotes is string && data.reflectionNotes.size() <= 5000)) &&
             (!('readingText' in data) || (data.readingText is string && data.readingText.size() <= 20000)) &&
             (!('paymentProvider' in data) || (data.paymentProvider is string && data.paymentProvider in ['stripe', 'app_store', 'google_play', 'daily_gift', 'welcome_bonus', 'admin_dusting'])) &&
             (!('idempotencyKey' in data) || data.idempotencyKey is string) &&
             (!('clientMetadata' in data) || (data.clientMetadata is map &&
                                              data.clientMetadata.userAgent is string &&
                                              data.clientMetadata.os is string &&
                                              data.clientMetadata.appVersion is string));
    }

    function isValidAiFeedback(data) {
      return data.userId == request.auth.uid &&
             data.transactionId is string &&
             data.rating is int &&
             data.rating >= 1 && data.rating <= 5 &&
             (!('comment' in data) || data.comment == null || (data.comment is string && data.comment.size() <= 1000)) &&
             data.createdAt == request.time;
    }



    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isEmployee());
      allow list: if request.auth != null && isEmployee();
      allow create, update: if request.auth != null && (request.auth.uid == userId || isEmployee()) && isValidUser(request.resource.data);
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /admin_users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin' || request.auth.token.role == 'employee');
      allow write: if false;
    }

    match /user_moons/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isEmployee());
      allow create: if request.auth != null && 
                    (
                      (request.auth.uid == userId && 
                       isValidUserMoon(request.resource.data) && 
                       (
                         (request.resource.data.balance == 1 && 
                          (!('dailyFreeBalance' in request.resource.data) || request.resource.data.dailyFreeBalance == 0) &&
                          (!('purchasedBalance' in request.resource.data) || request.resource.data.purchasedBalance == 1))
                         ||
                         (request.resource.data.balance == 5)
                       ))
                      ||
                      isEmployee()
                    );
      allow update: if request.auth != null && 
                    (
                      (request.auth.uid == userId && 
                       isValidUserMoon(request.resource.data) && 
                       (
                         // Case A: Harcama (Spend) - Bakiye 1 azalır
                         (
                           request.resource.data.balance == resource.data.balance - 1 &&
                           (
                             // Option 1: dailyFree'den düşüş
                             (resource.data.dailyFreeBalance > 0 && 
                              request.resource.data.dailyFreeBalance == resource.data.dailyFreeBalance - 1 &&
                              request.resource.data.purchasedBalance == resource.data.purchasedBalance)
                             ||
                             // Option 2: purchased'dan düşüş
                             (resource.data.dailyFreeBalance == 0 && 
                              request.resource.data.dailyFreeBalance == 0 &&
                              request.resource.data.purchasedBalance == resource.data.purchasedBalance - 1)
                             ||
                             // Option 3: Fallback (Eski şema için)
                             (!('dailyFreeBalance' in resource.data) || !('purchasedBalance' in resource.data))
                           )
                         )
                         ||
                         // Case B: Günlük Hak Alımı (Daily Claim)
                         (
                           request.resource.data.dailyFreeBalance == 1 &&
                           request.resource.data.purchasedBalance == resource.data.purchasedBalance &&
                           request.resource.data.balance == resource.data.purchasedBalance + 1 &&
                           request.resource.data.lastDailyClaimedAt == request.time &&
                           (
                             resource.data.lastDailyClaimedAt == null || 
                             request.time.toMillis() - resource.data.lastDailyClaimedAt.toMillis() >= 24 * 60 * 60 * 1000
                           )
                         )
                         ||
                         // Case C: Rollback / Refund (İade/Geri Alma) - Bakiye 1 artar
                         (
                           request.resource.data.balance == resource.data.balance + 1 &&
                           (
                             // Option 1: dailyFree'ye iade
                             (request.resource.data.dailyFreeBalance == resource.data.dailyFreeBalance + 1 &&
                              request.resource.data.purchasedBalance == resource.data.purchasedBalance)
                             ||
                             // Option 2: purchased'a iade
                             (request.resource.data.dailyFreeBalance == resource.data.dailyFreeBalance &&
                              request.resource.data.purchasedBalance == resource.data.purchasedBalance + 1)
                           )
                         )
                       ))
                      ||
                      isEmployee()
                    );
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /moon_transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isEmployee());
      allow create: if request.auth != null && 
                    (request.resource.data.userId == request.auth.uid || isEmployee()) && 
                    isValidMoonTransaction(request.resource.data, transactionId) &&
                    request.resource.data.paymentProvider is string &&
                    request.resource.data.idempotencyKey is string &&
                    request.resource.data.clientMetadata is map;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isEmployee()) && isValidMoonTransaction(request.resource.data, transactionId);
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /ai_feedback/{feedbackId} {
      allow get: if request.auth != null && (resource.data.userId == request.auth.uid || isEmployee());
      allow list: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'employee' || resource.data.userId == request.auth.uid);
      allow create, update: if request.auth != null && (request.auth.uid == request.resource.data.userId) && isValidAiFeedback(request.resource.data);
      allow delete: if request.auth != null && isEmployee();
    }


    match /messages_en/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_tr/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_es/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_fr/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_zh/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }
    match /messages_ko/{messageId} {
      allow create: if isValidMessage(request.resource.data);
      allow read, update, delete: if false;
    }

    match /phones/{phoneNumber} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /marketing_consents/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /checkout_attempts/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if false;
    }

    match /error_logs/{logId} {
      allow create: if request.resource.data.source == 'client' &&
                    (request.resource.data.userId == null || (request.auth != null && request.resource.data.userId == request.auth.uid));
      allow read: if request.auth != null && isEmployee();
      allow update, delete: if false;
    }

    match /ai_telemetry/{telemetryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /ui_configs/{configId} {
      allow read: if true;
      allow write: if isEmployee();
    }

    match /user_push_tokens/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isEmployee());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /system_configs/{configId} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    match /admin_audit_logs/{logId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null && (isEmployee() || isAdmin());
      allow update, delete: if false;
    }

    match /config_logs/{logId} {
      allow read: if request.auth != null && (isEmployee() || isAdmin());
      allow write: if false;
    }

  }
}
